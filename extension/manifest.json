{
  "manifest_version": 3,
  "name": "TradingView Squad",
  "version": "0.1.0",
  "description": "Voice chat, screen share, and live chart presence with your friends on TradingView.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.tradingview.com/*",
    "http://localhost:8080/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/chart/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "TradingView Squad"
  }
}
